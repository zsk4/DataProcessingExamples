{"version":3,"kind":"Notebook","sha256":"8ebd64c04e53e41cc66c5b17769ce00b430e6eeafd2db57df67bec9027557b85","slug":"gnss-filterevents","location":"/GNSS/GNSS_FilterEvents.ipynb","dependencies":[],"frontmatter":{"kernelspec":{"name":"python3","display_name":"gps","language":"python"},"github":"https://github.com/zsk4/DataProcessingExamples","numbering":{"title":{"offset":1}},"source_url":"https://github.com/zsk4/DataProcessingExamples/blob/main/GNSS/GNSS_FilterEvents.ipynb","edit_url":"https://github.com/zsk4/DataProcessingExamples/edit/main/GNSS/GNSS_FilterEvents.ipynb","exports":[{"format":"ipynb","filename":"GNSS_FilterEvents.ipynb","url":"/GNSS_FilterEvents-3a95176999ab93f6d006598c708cb086.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Zachary Katz\n# zachary_katz@mines.edu\n# 02 February 2024\n\n\"\"\"\nLoad feature csv [Obtained from https://github.com/MinesGlaciology/whillans-surf/blob/main/notebooks/data_preproc/09-18.csv] and time to next slip csv.\nFilter events that have a time to next slip.\n\"\"\"\n\n# Imports and Extensions\nimport pandas as pd\n\n# Load data\nfeature_df = pd.read_csv(\"./_Data/features.csv\")\ntime_to_slip_df = pd.read_csv(\"./_Data/filtered_time_to_next_event.csv\", index_col=0)\nassert feature_df.shape[0] == time_to_slip_df.shape[0], \"Dataframe missing events\"\n\n# Merge dataframes and drop events without a time to next slip or prior slip\nmerged_df = feature_df.merge(time_to_slip_df, left_index=True, right_index=True)\nmerged_df = merged_df[(merged_df[\"time_to_next_ev_hr\"] != -1) & (merged_df[\"time_since_prior_ev_hr\"] != -1)]\nmerged_df.to_csv(\"./_Data/filtered_features.csv\")\nmerged_df.head()\n\n\n","key":"zw7IOmyzi2"},{"type":"outputs","id":"KPGUVKXn8B1TcewiwKW_g","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":24,"metadata":{},"data":{"text/html":{"content":